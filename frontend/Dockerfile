# Questo Dockerfile verrà completato nella Fase 4
# quando il progetto Angular sarà inizializzato con Angular CLI

# ========================
# Stage 1: build
# ========================
# FROM node:20-alpine AS builder
# WORKDIR /app
# COPY package*.json ./
# RUN npm ci
# COPY . .
# RUN npm run build

# ========================
# Stage 2: production
# ========================
# FROM node:20-alpine AS production
# WORKDIR /app
# COPY --from=builder /app/dist ./dist
# COPY --from=builder /app/node_modules ./node_modules
# EXPOSE 4200
# CMD ["node", "dist/officina/server/main.js"]
